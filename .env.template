# AI Coding Agent - Environment Variables Template
# Copy this to .env and fill in your values (or set as Replit Secrets)

# GitHub Personal Access Token
# Get from: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:user, read:org
GITHUB_PAT=your_github_pat_here

# NVIDIA API Key (OpenAI-compatible)
# Get from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Server Configuration
PORT=3001
NODE_ENV=development
